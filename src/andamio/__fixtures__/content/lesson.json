    "slt_index": 1,
    "slt_text": "I can explain how the Andamio Issuer product differs from the Andamio API.",
    "created_by": "james",
    "content": {
      "title": "Two Products, Two Jobs: Issuer and API",
      "content_json": {
        "type": "doc",
        "content": [
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Andamio comes in two products. Both work with verifiable, on-chain credentials,"
              },
              {
                "type": "text",
                "text": " but they are built for different people."
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "marks": [
                  {
                    "type": "bold"
                  }
                ],
                "text": "Who handles the blockchain."
              },
              {
                "type": "text",
                "text": " With Andamio Issuer the blockchain is completely abstracted away."
              }
            ]
          }
        ]
      }
    },
    "source": "merged"
  }
}
