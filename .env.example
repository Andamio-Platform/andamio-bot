# ===========================================================================
# Andamio Discord Bot — environment template
# ---------------------------------------------------------------------------
# Copy to `.env` (`cp .env.example .env`) and fill in. The bot validates these
# on startup and FAILS FAST, naming the first missing var or malformed URL.
# Required vars must be set; optional vars have safe defaults if omitted.
# This is a TEMPLATE — set config here, no code changes needed.
# ===========================================================================

# --- Discord (required) ----------------------------------------------------

# Discord bot token (Developer Portal > your app > Bot > Reset Token).
DISCORD_TOKEN=your_discord_bot_token_here

# Discord application (client) id (Developer Portal > your app > General Information).
DISCORD_APP_ID=your_discord_application_id_here

# Discord guild (server) id the bot operates in (right-click server > Copy Server ID).
GUILD_ID=your_discord_guild_id_here

# --- Andamio (required) ----------------------------------------------------

# andamioscan base URL — the public read API the bot calls for credentials
# (GET /api/v2/users/{alias}/state). No trailing slash. No JWT/API key needed.
# This is the andamioscan explorer host, NOT api.andamio.io (the auth-gated
# db-api, which returns 401 on this path). Mainnet: https://andamioscan.io
SCAN_BASE_URL=https://preprod.andamioscan.io

# Andamio app base URL hosting the CLI login flow (/auth/cli). No trailing
# slash. `/login` sends users here to authenticate.
# Preprod — confirm exact host.
APP_LOGIN_BASE_URL=https://preprod-app.andamio.io

# Public https base URL where the bot receives the auth callback
# (GET <this>/callback). This must be reachable from the user's browser, and
# its ORIGIN must be in the Andamio app's ALLOWED_BOT_CALLBACK_ORIGINS
# allowlist (see README > Operating notes). No trailing slash.
# Preprod — set to your bot's public host.
BOT_CALLBACK_BASE_URL=https://your-bot-host.example.com

# --- Bot files (required) --------------------------------------------------

# Path to the role-mappings JSON config (see config/role-mappings.example.json).
ROLE_MAPPINGS_PATH=./config/role-mappings.json

# Path to the SQLite database file (created on first run).
DB_PATH=./data/bot.sqlite

# --- Optional --------------------------------------------------------------

# OPTIONAL: course_id -> display-name map for /credentials, as a JSON object.
# andamioscan returns course IDs, not titles; this shows friendly names instead.
# An unset or malformed value silently falls back to the raw course_id — it
# never breaks a command. Independent of role-mappings.json. Default: {} (raw ids).
# COURSE_DISPLAY_NAMES={"course_cardano_101":"Cardano 101","course_plutus":"Plutus Basics"}

# OPTIONAL: interval (ms) for the periodic gating sweep that re-evaluates every
# connected member's roles, so credentials earned/lost since their last
# interaction apply without a re-login. Must be a positive number; anything else
# falls back to the default. Default: 900000 (15 minutes).
# GATING_SWEEP_INTERVAL_MS=900000

# OPTIONAL: port the callback web server listens on. Default: 3000. Set this if
# your host expects the service on a specific port (many PaaS hosts inject PORT).
# PORT=3000
